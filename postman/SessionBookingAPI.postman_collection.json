{
  "info": {
    "name": "Session Booking API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "teacherId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "sessionId", "value": "" }
  ],
  "item": [
    {
      "name": "Create Teacher",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('teacherId', pm.response.json().id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"specialization\": \"Mathematics\",\n  \"experience\": 5\n}"
        },
        "url": "{{baseUrl}}/teachers"
      }
    },
    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('userId', pm.response.json().id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"9876543210\"\n}"
        },
        "url": "{{baseUrl}}/users"
      }
    },
    {
      "name": "Create Session",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('sessionId', pm.response.json().id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"teacherId\": \"{{teacherId}}\",\n  \"startTime\": \"2026-07-15T10:00:00.000Z\",\n  \"endTime\": \"2026-07-15T11:00:00.000Z\"\n}"
        },
        "url": "{{baseUrl}}/sessions"
      }
    },
    {
      "name": "Get Available Sessions",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/sessions/available?dateTimestamp=1784073600000",
          "host": ["{{baseUrl}}"],
          "path": ["sessions", "available"],
          "query": [{ "key": "dateTimestamp", "value": "1784073600000" }]
        }
      }
    },
    {
      "name": "Book Session",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\"\n}"
        },
        "url": "{{baseUrl}}/sessions/{{sessionId}}/book"
      }
    },
    {
      "name": "Complete Session",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/sessions/{{sessionId}}/complete"
      }
    },
    {
      "name": "Get User Sessions",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/{{userId}}/sessions"
      }
    }
  ]
}
